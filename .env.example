# 基线配置（全环境通用，优先被加载）
# 用法：cp .env.example .env 后按需修改；再用 make env-init 生成各环境文件
#
# 可选：不写 APP_ENV 时，会默认加载 .env.development（与未设置时的默认端口一致）
# APP_ENV=development

# 监听（launchd / plist 推荐用 HTTP_ADDR 一次写全）
# HTTP_ADDR=0.0.0.0:8090
# LISTEN_ADDR 与 HTTP_ADDR 等价（任选其一）
# 未设 HTTP_ADDR 时：可用 HOST + PORT，或仅 PORT（等价于 :PORT，监听所有网卡）
# HOST=0.0.0.0
PORT=8080

# Meilisearch（与 MEILISEARCH_HOST / MEILISEARCH_API_KEY 二选一场景）
# MEILISEARCH_HOST=http://localhost:7700
# MEILISEARCH_API_KEY=

# Deepseek（示例，请换为真实密钥）
DEEPSEEK_API_KEY=
DEEPSEEK_ADDRESS=https://api.deepseek.com

# MySQL
BASE_MYSQL_URL=http://localhost
BASE_MYSQL_PORT=3306
BASE_MYSQL_USER=root
BASE_MYSQL_PASS=
BASE_MYSQL_DATABASE=media_operator

# 同步/索引侧 Meilisearch（与 BASE_DB_MEILISEARCH_* 一致时可单独覆盖）
BASE_DB_MEILISEARCH_URL=http://localhost
BASE_DB_MEILISEARCH_PORT=7700
BASE_DB_MEILISEARCH_MASTER_KEY=
BASE_DB_MEILISEARCH_INDEX=media
